{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug all Selenium tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/mocha/bin/mocha.js",
      "args": ["test/**/*.spec.js"],
      "cwd": "${workspaceFolder}",
      "runtimeArgs": ["--inspect-brk"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug promise test",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/mocha/bin/mocha.js",
      "args": ["test/login.promise.spec.js"],
      "cwd": "${workspaceFolder}",
      "runtimeArgs": ["--inspect-brk"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug async test",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/mocha/bin/mocha.js",
      "args": ["test/login.async.spec.js"],
      "cwd": "${workspaceFolder}",
      "runtimeArgs": ["--inspect-brk"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}